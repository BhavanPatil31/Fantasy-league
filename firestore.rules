rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isGlobalAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'bhavanspatil2004@gmail.com' && 
        request.auth.token.email_verified == true
      );
    }

    function isOwner(contestId) {
      return isSignedIn() && 
        get(/databases/$(database)/documents/contests/$(contestId)).data.creatorId == request.auth.uid;
    }

    function isContestAdmin(contestId) {
      return isOwner(contestId) || isGlobalAdmin();
    }

    match /contests/{contestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.creatorId == request.auth.uid || isGlobalAdmin());
      allow delete: if isSignedIn() && (resource.data.creatorId == request.auth.uid || isGlobalAdmin());
      
      match /players/{playerId} {
        allow read: if isSignedIn();
        allow write: if isContestAdmin(contestId);
      }

      match /matches/{matchId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isContestAdmin(contestId);
      }

      match /fixtures/{fixtureId} {
        allow read: if isSignedIn();
        allow write: if isContestAdmin(contestId);
      }
    }
  }
}
